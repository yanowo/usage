# Local configuration. main.py loads .env from the current directory first,
# then from this project directory. Command-line flags still override these.

# web, desktop, or tui. Leave empty to keep the platform default.
USAGE_MODE=web

USAGE_WEB_HOST=127.0.0.1
USAGE_WEB_PORT=8765
USAGE_INTERVAL=60
USAGE_MOCK=0
USAGE_DEBUG=0

# Optional: point Codex lookup at a specific executable.
# USAGE_CODEX_COMMAND=C:\Users\Yan\AppData\Local\Programs\Codex\codex.exe

# Optional TUI test override: 0=Idle, 1=Normal, 2=Active, 3=Heavy.
# USAGE_FORCE_GROUP=0
